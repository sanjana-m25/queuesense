# .env.example — copy to .env.local and fill in real values
# NEVER commit .env.local to git

# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Google Maps ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── Hospital Config ─────────────────────────────────────────────────────────
HOSPITAL_LAT=
HOSPITAL_LNG=
HOSPITAL_NAME=
HOSPITAL_ID=

# ─── Twilio (SMS) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── WATI (WhatsApp — optional, preferred for India) ──────────────────────────
WATI_API_KEY=
WATI_ENDPOINT=

# ─── Cron Security ────────────────────────────────────────────────────────────
CRON_SECRET=

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
QUEUE_RECALC_INTERVAL_SECONDS=45
CONSENT_NOTIFICATION_WINDOW_MINUTES=35
